# Lead generation — raccolta email opt-in al primo avvio (PLAN_LEAD_GENERATION.md §4)
#
# COME USARLO:
#   1. copia questo file in  desktop-electron/.env   (il .env NON viene committato)
#   2. incolla il valore del token dopo  LEADS_APP_TOKEN=
#      (il token sta nel repo privato  qwibo-leads/secret/  — MAI qui, mai in git)
#
# Senza un valore in LEADS_APP_TOKEN la feature resta DISATTIVATA:
# niente modal al primo avvio, nessuna chiamata di rete.

LEADS_API_URL=https://qwiboleads.antoniotrento.net/v1/leads
LEADS_APP_TOKEN=
